# Backend API - Variables de Entorno

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos (Turso / LibSQL)
# Obtén estos valores en: https://app.turso.tech -> tu DB -> Connect
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_token_here

# JWT / Auth
JWT_SECRET=cambia_este_secreto_en_produccion_minimo_16_chars
JWT_EXPIRES_IN=7d

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=info@camarainmobiliariadebolivar.com
ADMIN_EMAIL=info@camarainmobiliariadebolivar.com

# Supabase Storage (Opcional, para carga de archivos)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_STORAGE_PUBLIC_BUCKET=public-docs

# Frontend (para links en correos)
APP_URL=http://localhost:5173

# CORS (Lista separada por comas)
CORS_ORIGINS=http://localhost:5173,https://cim-front.vercel.app
